    "php": ">=8.1",
    "mongodb/mongodb": "^1.18",
    "ext-mongodb": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "includes/"
    }
  },
  "config": {
    "optimize-autoloader": true
  }
}
