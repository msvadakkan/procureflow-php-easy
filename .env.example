# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=purchase_approval

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-string

# ── App URL (no trailing slash) ───────────────────────────────────────────────
APP_URL=https://yourdomain.com

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Optional — leave SMTP_USER blank to disable email notifications entirely.
# Works with any SMTP provider (Gmail, Outlook, Office 365, custom).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
